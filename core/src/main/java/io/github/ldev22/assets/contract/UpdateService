public class ContractUpdateService : IContractUpdateService
{
    private readonly ISnowflakeConnectionFactory _connectionFactory;
    private readonly DatabaseConfig _dbConfig;

    public ContractUpdateService(ISnowflakeConnectionFactory connectionFactory, DatabaseConfig dbConfig)
    {
        _connectionFactory = connectionFactory ?? throw new ArgumentNullException(nameof(connectionFactory));
        _dbConfig = dbConfig ?? throw new ArgumentNullException(nameof(dbConfig));

        LambdaLogger.Log("INFO: ContractUpdateService initialized successfully.");
    }

    public async Task<ResponseData> UpdateContract(RequestData input)
    {
        LambdaLogger.Log($"INFO: UpdateContract called with input: {JsonConvert.SerializeObject(input)}");

        var response = new ResponseData();

        try
        {
            using var connection = _connectionFactory.CreateConnection();
            await connection.OpenAsync();

            // Generate a new ContractDetailId if one does not exist
            var contractDetailId = string.IsNullOrWhiteSpace(input.ContactDetail?.ContractDetailId)
                ? Guid.NewGuid().ToString()
                : input.ContactDetail.ContractDetailId;

            using var command = connection.CreateCommand();

            // Snowflake MERGE with positional parameters (?)
            command.CommandText = @"
        MERGE INTO CONTRACT_DETAILS t
        USING (
            SELECT
                ? AS CASE_ID,
                ? AS CONTRACT_DETAIL_ID
        ) s
        ON t.CONTRACT_DETAIL_ID = s.CONTRACT_DETAIL_ID

        WHEN MATCHED THEN UPDATE SET
            CONTRACT_NUMBER = ?,
            PRODUCT_NAME = ?,
            INVEST_TYPE = ?,
            INVEST_AMOUNT = ?,
            PAY_METHOD = ?,
            COMM_ALLOWANCE = ?,
            FP_FEE = ?,
            NEG_COMM_ALLOWANCE = ?,
            NEG_COMM_PERCENTAGE = ?,
            MODIFIED_BY = ?,
            MODIFIED_ON = CURRENT_TIMESTAMP()

        WHEN NOT MATCHED THEN INSERT (
            CONTRACT_DETAIL_ID,
            CASE_ID,
            CONTRACT_NUMBER,
            PRODUCT_NAME,
            INVEST_TYPE,
            INVEST_AMOUNT,
            PAY_METHOD,
            COMM_ALLOWANCE,
            FP_FEE,
            NEG_COMM_ALLOWANCE,
            NEG_COMM_PERCENTAGE,
            CREATED_BY,
            CREATED_ON
        )
        VALUES (
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            CURRENT_TIMESTAMP()
        );
    ";

            // Add parameters in exact order
            AddPositionalParameter(command, input.CaseId);                         // 1
            AddPositionalParameter(command, input.ContactDetail?.ContractDetailId); // 2

            AddPositionalParameter(command, input.ContactDetail?.ContractNumber);  // 3
            AddPositionalParameter(command, input.ContactDetail?.ProductName);     // 4
            AddPositionalParameter(command, input.ContactDetail?.InvestType);      // 5
            AddPositionalParameter(command, input.ContactDetail?.InvestAmount);    // 6
            AddPositionalParameter(command, input.ContactDetail?.PayMethod);       // 7
            AddPositionalParameter(command, input.ContactDetail?.CommAllowance);   // 8
            AddPositionalParameter(command, input.ContactDetail?.FpFee);           // 9
            AddPositionalParameter(command, input.ContactDetail?.NegCommAllowance);// 10
            AddPositionalParameter(command, input.ContactDetail?.NegCommPercentage);// 11
            AddPositionalParameter(command, input.ContactDetail?.ModifiedBy);      // 12

            AddPositionalParameter(command, contractDetailId);                     // 13
            AddPositionalParameter(command, input.CaseId);                         // 14
            AddPositionalParameter(command, input.ContactDetail?.ContractNumber);  // 15
            AddPositionalParameter(command, input.ContactDetail?.ProductName);     // 16
            AddPositionalParameter(command, input.ContactDetail?.InvestType);      // 17
            AddPositionalParameter(command, input.ContactDetail?.InvestAmount);    // 18
            AddPositionalParameter(command, input.ContactDetail?.PayMethod);       // 19
            AddPositionalParameter(command, input.ContactDetail?.CommAllowance);   // 20
            AddPositionalParameter(command, input.ContactDetail?.FpFee);           // 21
            AddPositionalParameter(command, input.ContactDetail?.NegCommAllowance);// 22
            AddPositionalParameter(command, input.ContactDetail?.NegCommPercentage);// 23
            AddPositionalParameter(command, input.ContactDetail?.CreatedBy);       // 24

            await command.ExecuteNonQueryAsync();

            response.Data.NewContractDetailId = contractDetailId;
        }
        catch (Exception ex)
        {
            ex = ex.InnerException ?? ex;
            LambdaLogger.Log($"ERROR: {ex.Message} | StackTrace: {ex.StackTrace}");
            throw;
        }

        LambdaLogger.Log($"INFO: UpdateContract completed. Response: {JsonConvert.SerializeObject(response)}");
        return response;
    }

    // Helper method for positional parameters
    private void AddPositionalParameter(IDbCommand command, object value)
    {
        var param = command.CreateParameter();
        param.Value = value ?? DBNull.Value;
        // Do NOT set ParameterName for positional binding
        command.Parameters.Add(param);
    }
}
